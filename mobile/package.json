  "main": "src/main.ts",
  "scripts": {
    "postinstall": "node -e \"require('fs').existsSync('.env') || require('fs').copyFileSync('.env.example', '.env')\"",
    "commit": "cd .. && pnpm run commit",
    "development": "expo start",
    "dev": "pnpm run development",
    "build:dev": "eas build -e development -p android",
    "build:stage": "eas build -e preview -p android",
    "build": "eas build -p android",
    "lint": "eslint --fix src/ eslint.config.mjs app.config.ts"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "~0.4.2",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "axios": "^1.15.2",
    "dotenv-flow": "^4.1.0",
    "expo": "^55.0.17",
    "expo-build-properties": "~55.0.13",
    "expo-dev-client": "~55.0.28",
    "expo-font": "~55.0.6",
    "expo-image-picker": "~55.0.19",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-maps": "~1.27.2",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-any": "^2.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
