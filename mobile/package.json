  "main": "src/main.ts",
  "scripts": {
    "postinstall": "node -e \"require('fs').existsSync('.env') || require('fs').copyFileSync('.env.example', '.env')\"",
    "commit": "cd .. && pnpm run commit",
    "development": "expo start",
    "dev": "pnpm run development",
    "build:dev": "eas build -e development -p android",
    "build:stage": "eas build -e preview -p android",
    "build": "eas build -p android",
    "lint": "eslint --fix src/ eslint.config.mjs app.config.ts"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "~0.4.2",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.6.16",
    "axios": "^1.13.2",
    "dotenv-flow": "^4.1.0",
    "expo": "^54.0.31",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "~1.20.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@types/react": "~19.1.17",
    "eslint": "^9.39.2",
    "eslint-config-any": "^2.3.0",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3"
  }
